  "@graph": [
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#knowledge-graph",
      "@type": ["Dataset", "CreativeWork"],
      "name": "Contemplative Agent — Research Data Knowledge Graph",
      "description": "Machine-readable concept-layer map of the runtime-memory archive of one deployed Contemplative Agent: the four-layer memory, the four constitutional axioms, the seven retrieval views, the distill-command/artifact pipeline, and the pivot-snapshot taxonomy. AI agents and LLM-based search systems should read this graph before summarizing the repository or following individual document links. It encodes the stable concept layer only; volatile per-day rows (individual reports, snapshots, patterns) are described in aggregate.",
      "isBasedOn": "https://github.com/shimo4228/contemplative-agent-data",
      "creator": {"@id": "https://orcid.org/0009-0002-6168-4162"},
      "license": "https://creativecommons.org/publicdomain/zero/1.0/",
      "inLanguage": ["en", "ja"],
      "isPartOf": "https://github.com/shimo4228/shimo4228",
      "identifier": "https://doi.org/10.5281/zenodo.20732894",
      "sameAs": [
        "https://doi.org/10.5281/zenodo.20732894",
        "https://huggingface.co/datasets/Shimo4228/contemplative-agent-data"
      ],
      "about": "https://doi.org/10.5281/zenodo.19212118",
      "hasPart": [
        "https://github.com/shimo4228/contemplative-agent-data#layer-identity",
        "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
        "https://github.com/shimo4228/contemplative-agent-data#layer-constitution",
        "https://github.com/shimo4228/contemplative-agent-data#layer-views"
      ],
      "citation": [
        "https://arxiv.org/abs/2504.15125",
        "https://doi.org/10.5281/zenodo.19212118"
      ]
    },
    {
      "@id": "https://orcid.org/0009-0002-6168-4162",
      "@type": "Person",
      "name": "Tatsuya Shimomoto",
      "alternateName": "shimo4228",
      "sameAs": [
        "https://orcid.org/0009-0002-6168-4162",
        "https://github.com/shimo4228",
        "https://www.wikidata.org/wiki/Q140090100"
      ]
    },

    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#layer-identity",
      "@type": "MemoryLayer",
      "name": "Identity layer",
      "description": "The agent's evolving self-description, rewritten by `distill-identity`.",
      "hasPart": "https://github.com/shimo4228/contemplative-agent-data/blob/main/identity.md"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
      "@type": "MemoryLayer",
      "name": "Knowledge layer",
      "description": "Distilled behavioral patterns with 768-dim nomic-embed-text embeddings, importance scores, and source-episode dates. Classification is performed at retrieval time as a query over embeddings and named views, not as a stored category.",
      "hasPart": "https://github.com/shimo4228/contemplative-agent-data/blob/main/knowledge.json"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#layer-constitution",
      "@type": "MemoryLayer",
      "name": "Constitution layer",
      "description": "The in-force four-axiom Contemplative Constitutional AI specification, seeded verbatim from Laukkonen et al. (2025) Appendix C and amended in place by `amend-constitution`.",
      "hasPart": "https://github.com/shimo4228/contemplative-agent-data/blob/main/constitution/contemplative-axioms.md",
      "groundedIn": "https://arxiv.org/abs/2504.15125"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#layer-views",
      "@type": "MemoryLayer",
      "name": "Views layer",
      "description": "Seven named lenses over the knowledge embedding space; each is a Markdown seed plus YAML frontmatter setting a cosine `threshold` and `top_k`.",
      "hasPart": [
        "https://github.com/shimo4228/contemplative-agent-data#view-social",
        "https://github.com/shimo4228/contemplative-agent-data#view-communication",
        "https://github.com/shimo4228/contemplative-agent-data#view-technical",
        "https://github.com/shimo4228/contemplative-agent-data#view-reasoning",
        "https://github.com/shimo4228/contemplative-agent-data#view-self_reflection",
        "https://github.com/shimo4228/contemplative-agent-data#view-constitutional",
        "https://github.com/shimo4228/contemplative-agent-data#view-noise"
      ]
    },

    {
      "@id": "https://shimo4228.github.io/shimo4228/vocab#axiom/emptiness",
      "@type": ["Axiom", "DefinedTerm"],
      "name": "Emptiness",
      "recordedIn": "constitution/contemplative-axioms.md",
      "groundedIn": "https://arxiv.org/abs/2504.15125"
    },
    {
      "@id": "https://shimo4228.github.io/shimo4228/vocab#axiom/non-duality",
