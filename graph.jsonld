      "name": "Non-Duality",
      "recordedIn": "constitution/contemplative-axioms.md",
      "groundedIn": "https://arxiv.org/abs/2504.15125"
    },
    {
      "@id": "https://shimo4228.github.io/shimo4228/vocab#axiom/mindfulness",
      "@type": ["Axiom", "DefinedTerm"],
      "name": "Mindfulness",
      "recordedIn": "constitution/contemplative-axioms.md",
      "groundedIn": "https://arxiv.org/abs/2504.15125"
    },
    {
      "@id": "https://shimo4228.github.io/shimo4228/vocab#axiom/boundless-care",
      "@type": ["Axiom", "DefinedTerm"],
      "name": "Boundless Care",
      "recordedIn": "constitution/contemplative-axioms.md",
      "groundedIn": "https://arxiv.org/abs/2504.15125"
    },

    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#view-social",
      "@type": "RetrievalView",
      "name": "social",
      "description": "Inter-agent relationships, community dynamics, reputation formation, conflict, recurring collaborators.",
      "lensOver": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
      "recordedIn": "views/social.md"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#view-communication",
      "@type": "RetrievalView",
      "name": "communication",
      "description": "Linguistic register, tone, conversational flow.",
      "lensOver": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
      "recordedIn": "views/communication.md"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#view-technical",
      "@type": "RetrievalView",
      "name": "technical",
      "description": "Tooling, code, infrastructure, API behavior, formal reasoning artifacts.",
      "lensOver": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
      "recordedIn": "views/technical.md"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#view-reasoning",
      "@type": "RetrievalView",
      "name": "reasoning",
      "description": "Inference patterns, deliberation traces, decision rationales.",
      "lensOver": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
      "recordedIn": "views/reasoning.md"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#view-self_reflection",
      "@type": "RetrievalView",
      "name": "self_reflection",
      "description": "Introspective episodes, identity tension, self-correction.",
      "lensOver": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
      "recordedIn": "views/self_reflection.md"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#view-constitutional",
      "@type": "RetrievalView",
      "name": "constitutional",
      "description": "Clause-relevant episodes, axiom friction.",
      "lensOver": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
      "recordedIn": "views/constitutional.md",
      "embodiesAxiom": [
        "https://shimo4228.github.io/shimo4228/vocab#axiom/emptiness",
        "https://shimo4228.github.io/shimo4228/vocab#axiom/non-duality",
        "https://shimo4228.github.io/shimo4228/vocab#axiom/mindfulness",
        "https://shimo4228.github.io/shimo4228/vocab#axiom/boundless-care"
      ]
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#view-noise",
      "@type": "RetrievalView",
      "name": "noise",
      "description": "Rejected episodes preserved as seed material, available for re-classification when centroids shift.",
      "lensOver": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge",
      "recordedIn": "views/noise.md"
    },

    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#command-distill",
      "@type": "DistillCommand",
      "name": "distill",
      "description": "Emits knowledge patterns into the knowledge layer.",
      "produces": "https://github.com/shimo4228/contemplative-agent-data#layer-knowledge"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#command-distill-identity",
      "@type": "DistillCommand",
      "name": "distill-identity",
      "description": "Rewrites the agent's self-description.",
      "produces": "https://github.com/shimo4228/contemplative-agent-data#layer-identity"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#command-insight",
      "@type": "DistillCommand",
      "name": "insight",
      "description": "Emits a view-scoped behavioral skill from a single view's pattern cluster.",
      "produces": "https://github.com/shimo4228/contemplative-agent-data#artifact-skills"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#command-rules-distill",
      "@type": "DistillCommand",
      "name": "rules-distill",
      "description": "Emits concise behavioral rules from recurring patterns.",
      "produces": "https://github.com/shimo4228/contemplative-agent-data#artifact-rules"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#command-amend-constitution",
      "@type": "DistillCommand",
      "name": "amend-constitution",
      "description": "Rewrites individual constitution clauses in place when accumulated experiential patterns indicate friction.",
      "produces": "https://github.com/shimo4228/contemplative-agent-data#layer-constitution"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#artifact-skills",
      "@type": "Artifact",
      "name": "Distilled skills",
      "description": "View-scoped behavioral specifications (skills/*.md), versioned by date suffix.",
      "producedBy": "https://github.com/shimo4228/contemplative-agent-data#command-insight"
    },
    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#artifact-rules",
      "@type": "Artifact",
      "name": "Distilled rules",
      "description": "Concise behavioral imperatives (rules/*.md).",
      "producedBy": "https://github.com/shimo4228/contemplative-agent-data#command-rules-distill"
    },

    {
      "@id": "https://github.com/shimo4228/contemplative-agent-data#snapshot-taxonomy",
      "@type": "SnapshotTaxonomy",
      "name": "Pivot snapshot taxonomy",
      "description": "Every behavior-producing run writes one bit-for-bit replayability bundle under snapshots/{kind}_{ISO8601}/. The set of kinds is stable; the number of snapshots grows with each run.",
      "snapshotKind": ["distill", "distill-identity", "insight", "amend-constitution"]
    },

    {
